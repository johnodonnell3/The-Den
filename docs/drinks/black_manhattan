<body>

<h1 class="drink-title">Black Manhattan</h1>

<img class="drink-photo" src="../images/black_manhattan.jpg">

<h2>Ingredients</h2>
<ul class="ingredients">
    <li>2 oz bourbon/rye whiskey</li>
    <li>1 oz Averna Amaro</li>
    <li>1 dash Angostura bitters</li>
    <li>1 dash orange bitters</li>
    <li>Cherry garnish</li>
</ul>

<h2>Instructions</h2>
<ol class="instructions">
    <li>Add ingredients to mixing glass with ice.</li>
    <li>Stir until chilled.</li>
    <li>Strain into coupe glass.</li>
    <li>Garnish with cherry.</li>
</ol>

